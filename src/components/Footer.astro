---
import { SITE, SOCIALS } from "@consts"
import Container from "@components/Container.astro"

const currentYear = new Date().getFullYear();
---

<footer class="relative bg-background">
  <div class="animate">
    <section class="py-6">
      <Container size="md">
        <div class="flex items-center justify-center sm:justify-end">
          <button id="back-to-top" aria-label="Back to top of page" class="group flex w-fit px-3 py-1.5 gap-2 text-sm items-center border border-border rounded-md text-foreground/60 hover:text-foreground hover:bg-foreground/5 blend">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-current rotate-90">
              <line x1="19" y1="12" x2="5" y2="12" />
              <polyline points="12 19 5 12 12 5" />
            </svg>
            <span>Back to top</span>
          </button>
        </div>
      </Container>
    </section>
  
    <section class="py-6 border-t border-border">
      <Container size="md">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex flex-col items-center sm:items-start">
            <a href="/" class="flex items-center gap-2 font-medium text-foreground hover:opacity-70 blend">
              <img src="/brand.png" class="size-5" alt="logo" />
              <span>{SITE.TITLE}</span>
            </a>
          </div>
          <div class="flex gap-2 justify-center sm:justify-end items-center text-sm text-foreground/60">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            <span>Active</span>
          </div>
        </div>
      </Container>
    </section>
  
    <section class="py-6 border-t border-border">
      <Container size="md">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="order-2 sm:order-1 flex flex-col items-center sm:items-start gap-2">
            <div class="flex gap-2 text-sm text-foreground/60">
              <a href="/legal/terms" class="hover:text-foreground blend">
                Terms
              </a>
              <span>|</span>
              <a href="/legal/privacy" class="hover:text-foreground blend">
                Privacy
              </a>
            </div>
            <div class="text-sm text-foreground/60">
              &copy; {currentYear} {SITE.TITLE}
            </div>
          </div>
  
          <div class="order-1 sm:order-2 flex justify-center sm:justify-end">
            <div class="flex flex-wrap gap-1 items-center">
              {
                SOCIALS.map((SOCIAL) => (
                  <a 
                    href={SOCIAL.HREF} 
                    target="_blank" 
                    aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`} 
                    class="size-8 rounded-md p-1.5 flex items-center justify-center text-foreground/60 hover:text-foreground hover:bg-foreground/5 border border-border blend"
                  >
                    <svg class="size-4 fill-current">
                      <use href={`/social.svg#${SOCIAL.ICON}`} />
                    </svg>
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </Container>
    </section>
  </div>

</footer>

<script is:inline>
  function goBackToTop(event) {
    event.preventDefault()
    window.scrollTo({
        top: 0,
        behavior: "smooth"
    })
  }

  function inintializeBackToTop() {
    const backToTop = document.getElementById("back-to-top")
    backToTop?.addEventListener("click", goBackToTop)
  }

  document.addEventListener("astro:after-swap", inintializeBackToTop)
  inintializeBackToTop()
</script>