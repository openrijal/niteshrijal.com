---
import { SITE, LINKS } from "@consts"
import { cn } from "@lib/utils"
const { pathname } = Astro.url
const subpath = pathname.match(/[^/]+/g)
---

<div id="drawer" class="fixed inset-0 h-0 z-40 overflow-hidden flex flex-col items-center justify-center md:hidden bg-background transition-[height] duration-200 ease-in-out">
  <nav class="flex flex-col items-center space-y-2">
    {
      LINKS.map((LINK) => (
        <a href={LINK.HREF} class={cn("flex items-center justify-center px-3 py-1.5 rounded-md", "text-foreground/60 hover:text-foreground hover:bg-foreground/5", "blend", pathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF ? "bg-foreground text-background" : "")}>
          {LINK.TEXT}
        </a>
      ))
    }
  </nav>

  <div class="flex gap-1 mt-5">
    <a href="/search" aria-label={`Search blog posts and projects on ${SITE.TITLE}`} class={cn("size-8 rounded-md p-1.5 items-center justify-center", "text-foreground/60 hover:text-foreground hover:bg-foreground/5", "border border-border", "blend", pathname === "/search" || "/" + subpath?.[0] === "search" ? "bg-foreground text-background border-foreground" : "")}>
      <svg class="size-4 stroke-current">
        <use href="/ui.svg#search"></use>
      </svg>
    </a>

    <a href="/rss.xml" target="_blank" aria-label={`Rss feed for ${SITE.TITLE}`} class="size-8 rounded-md p-1.5 items-center justify-center text-foreground/60 hover:text-foreground hover:bg-foreground/5 border border-border blend">
      <svg class="size-4 stroke-current">
        <use href="/ui.svg#rss"></use>
      </svg>
    </a>

    <a href="https://drive.google.com/file/d/1-mjqEv-7mQEDvgD5j631XiAfAmseUL8c/view?usp=sharing" target="_blank" aria-label={`Nitesh Rijal's Resume`} class="size-8 rounded-md p-1.5 items-center justify-center text-foreground/60 hover:text-foreground hover:bg-foreground/5 border border-border blend">
      <svg class="size-4 stroke-current">
        <use href="/ui.svg#download"></use>
      </svg>
    </a>

    <button id="drawer-theme-button" aria-label={`Toggle light and dark theme`} class="size-8 rounded-md p-1.5 items-center justify-center text-foreground/60 hover:text-foreground hover:bg-foreground/5 border border-border blend">
      <svg class="block dark:hidden size-4 stroke-current">
        <use href="/ui.svg#sun"></use>
      </svg>
      <svg class="hidden dark:block size-4 stroke-current">
        <use href="/ui.svg#moon"></use>
      </svg>
    </button>
  </div>
</div>

<style>
  #drawer.open {
    @apply h-full;
  }
</style>