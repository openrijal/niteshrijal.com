---

<PageLayout title="Home" description={SITE.DESCRIPTION}>
  <!-- HERO -->
  <section class="relative min-h-screen w-full flex items-center justify-center">
    <div class="animate text-center px-5">
      <p class='text-lg md:text-xl font-medium text-foreground/60 mb-2'>
        🙏 Namaste, I am ...
      </p>
      <h1 class='text-3xl md:text-4xl lg:text-5xl font-semibold text-foreground mb-3'>
        Nitesh Rijal
      </h1>
      <p class='text-base md:text-lg text-foreground/60 mb-8'>
        changing the world one line of code at a time
      </p>
      <div class='flex flex-wrap gap-3 justify-center'>
        <a href='/blog' class='px-4 py-2 rounded-md text-sm border border-border bg-foreground text-background hover:opacity-80 blend'>
          Read my blog
        </a>
        <a href='/projects' class='px-4 py-2 rounded-md text-sm border border-border text-foreground/60 hover:text-foreground hover:bg-foreground/5 blend'>
          View my projects
        </a>
      </div>
    </div>
  </section>

  <div class="relative bg-background">
    <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">

      <!-- About Section -->
      <section class="animate">
        <article>
          <p>I am a Software Engineer with a strong passion for open-source technologies and full-stack development. 
            Throughout my career, I have actively contributed to the open-source communities, demonstrating my expertise in both front-end and back-end development. 
            My commitment to writing clean, scalable code and my continuous pursuit of learning make me a valuable asset to any team.
          </p>
          <p>
            I have had the privilege of mentoring engineers at various stages in their careers, 
            aiming to create a positive impact on their lives. Guiding and empowering others to grow and succeed has been a rewarding experience, 
            and I take great pride in fostering a supportive and collaborative environment for professional development.
          </p>
        </article>
      </section>

      <!-- Blog Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <p class="font-medium text-foreground">
              Recent posts
            </p>
            <a href="/blog" class="text-sm text-foreground/60 hover:text-foreground underline underline-offset-2 decoration-foreground/30 hover:decoration-foreground blend">
              All posts
            </a>
          </div>
          <ul class="space-y-3">
            {posts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Tech Stack Section -->
       <!--
      <section class="animate">
        <div class="space-y-4">
          <p class="font-semibold text-black dark:text-white">
            Website build with
          </p>
          <div class="flex flex-wrap items-center gap-2 mt-5">
            {stack.map(item => (
              <StackCard 
                text={item.text}
                icon={item.icon}
                href={item.href}
              />
            ))}
          </div>
          <div>
            Performing reactivity and statefulness, special guest
            <a href="https://www.solidjs.com/" target="_blank" class="w-fit group underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                SolidJS
              </span>
            </a>
          </div>
        </div>
      </section>
       -->

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <p class="font-medium text-foreground">
              Recent projects
            </p>
            <a href="/projects" class="text-sm text-foreground/60 hover:text-foreground underline underline-offset-2 decoration-foreground/30 hover:decoration-foreground blend">
              All projects
            </a>
          </div>
          <ul class="space-y-3">
            {projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <p class="font-medium text-foreground mb-2">
            Let's Connect
          </p>
          <p class="text-foreground/60 mb-4">
            Reach out to me via email or on social media.
          </p>
          <div class="grid grid-cols-4 gap-y-2 auto-cols-min">
            {SOCIALS.map(social => (
              <>
                <div class="col-span-1 flex items-center">
                  <span class="text-sm text-foreground/60 whitespace-nowrap">
                    {social.NAME}
                  </span>
                </div>
                <div class="col-span-3">
                  <a href={social.HREF} target="_blank" class="text-sm text-foreground/60 hover:text-foreground underline underline-offset-2 decoration-foreground/30 hover:decoration-foreground blend">
                    {social.TEXT}
                  </a>
                </div>
              </>
            ))}
          </div>
        </div>
      </section>
    </div>
  </div>
</PageLayout>
